<%- include('layout', { body: `
<section class="page-header">
  <div>
    <h1>Available Found Items</h1>
    <p>These found items are currently held at the security gate. Submit a claim if you believe an item belongs to you.</p>
  </div>
</section>
<section class="notice-box notice-warning">
  <strong>⏰ Important:</strong> Items not claimed within 90 days may be archived or disposed of according to university policy.
</section>
${reports.length ? `
  <div class="items-grid">
    ${reports.map(r => `
      <div class="item-card">
        <div class="item-image">
          ${r.image_path ? `<img src="/${r.image_path}" alt="${r.title}">` : '<div class="no-image">📦 No Image</div>'}
        </div>
        <div class="item-info">
          <h3>${r.title}</h3>
          <p class="description">${r.description}</p>
          <div class="item-details">
            <p><strong>Location Found:</strong> ${r.location}</p>
            <p><strong>Reported:</strong> ${new Date(r.created_at).toLocaleDateString()}</p>
            <p><strong>Status:</strong> <span class="status-badge status-${r.status.replace(/\s+/g, '-')}">${r.status}</span></p>
            <p><strong>Claim requests:</strong> ${r.claim_requests || 0}</p>
            <p><strong>Security contact:</strong> ${r.contact_phone || '-'}</p>
          </div>
          <div class="item-actions">
            ${r.my_pending_claims > 0 ? `
              <div class="badge badge-yellow">Your claim is pending review</div>
            ` : [`in security`, `claim requested`].includes(r.status) ? `
              <form action="/student/claim/${r.id}" method="post" class="inline-form">
                <button type="submit" class="btn btn-success">Request to Claim</button>
              </form>
            ` : `
              <p class="text-muted">Not available for claim.</p>
            `}
          </div>
        </div>
      </div>
    `).join('')}
  </div>
` : '<p class="text-center">No claimable items are currently available. Check back later!</p>'}
` }) %>