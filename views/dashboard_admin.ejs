<%- include('layout', { 
  user, 
  error, 
  success,
  body: `
    <section class="page-header">
      <div>
        <h1>Admin Dashboard</h1>
        <p>Control accounts, review all lost and found reports, and keep the security office informed.</p>
      </div>
      <a class="button" href="/admin/add-user">Create new user</a>
    </section>

    <section class="dashboard-summary">
      <div class="status-card status-card-found">
        <h3>Total users</h3>
        <p>${users.length}</p>
      </div>
      <div class="status-card status-card-pending">
        <h3>Total reports</h3>
        <p>${reports.length}</p>
      </div>
    </section>

    <section class="section-grid">
      <div class="table-card" style="overflow-x:auto;">
        <h2>Users</h2>
        ${users.length ? `
          <table style="font-size:12px; font-family:inherit; min-width:100%; border-collapse:collapse;">
            <thead><tr style="background:#f5f5f5;"><th style="padding:8px;text-align:left;border-bottom:1px solid #ddd;">ID</th><th style="padding:8px;text-align:left;border-bottom:1px solid #ddd;max-width:120px;overflow:hidden;">Name</th><th style="padding:8px;text-align:left;border-bottom:1px solid #ddd;max-width:150px;overflow:hidden;">Email</th><th style="padding:8px;text-align:left;border-bottom:1px solid #ddd;max-width:100px;overflow:hidden;">User</th><th style="padding:8px;text-align:left;border-bottom:1px solid #ddd;">Role</th><th style="padding:8px;text-align:left;border-bottom:1px solid #ddd;max-width:110px;overflow:hidden;">Phone</th><th style="padding:8px;text-align:left;border-bottom:1px solid #ddd;white-space:nowrap;">Actions</th></tr></thead>
            <tbody>
              ${users.map(u => `
                <tr style="border-bottom:1px solid #eee;">
                  <td style="padding:8px;">${u.id}</td>
                  <td style="padding:8px;max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="${u.full_name}">${u.full_name}</td>
                  <td style="padding:8px;max-width:150px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="${u.email}">${u.email}</td>
                  <td style="padding:8px;max-width:100px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="${u.username}">${u.username}</td>
                  <td style="padding:8px;"><span style="background:#e8f4f8;padding:3px 8px;border-radius:3px;font-size:11px;">${u.role}</span></td>
                  <td style="padding:8px;max-width:110px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="${u.phone_number || '-'}">${u.phone_number || '-'}</td>
                  <td style="padding:8px;white-space:nowrap;">
                    <form method="post" action="/admin/user/${u.id}/delete" style="display:inline;margin-right:4px;">
                      <button class="btn btn-danger" onclick="return confirm('Delete user ${u.username}?')" style="font-size:11px;padding:4px 6px;background:#dc3545;color:white;border:none;border-radius:3px;cursor:pointer;">Delete</button>
                    </form>
                    <form method="post" action="/admin/user/${u.id}/role" style="display:inline;margin-right:4px;">
                      <select name="role" style="font-size:11px;padding:3px;border-radius:3px;border:1px solid #ddd;">
                        <option value="student" ${u.role==='student' ? 'selected' : ''}>student</option>
                        <option value="security" ${u.role==='security' ? 'selected' : ''}>security</option>
                        <option value="admin" ${u.role==='admin' ? 'selected' : ''}>admin</option>
                      </select>
                      <button style="font-size:11px;padding:4px 6px;margin-left:2px;background:#007bff;color:white;border:none;border-radius:3px;cursor:pointer;">Set</button>
                    </form>
                    <form method="post" action="/admin/user/${u.id}/reset-password" style="display:inline;margin-top:2px;">
                      <input name="password" placeholder="new pwd" style="font-size:11px;padding:3px;width:80px;border:1px solid #ddd;border-radius:3px;" />
                      <button style="font-size:11px;padding:4px 6px;margin-left:2px;background:#28a745;color:white;border:none;border-radius:3px;cursor:pointer;">Reset</button>
                    </form>
                  </td>
                </tr>
              `).join('')}
            </tbody>
          </table>
        ` : '<p>No users found.</p>'}
      </div>
      <div class="table-card">
        <h2>All reports</h2>
        ${reports.length ? `
          <table>
            <thead><tr><th>ID</th><th>Type</th><th>Title</th><th>Status</th><th>Location</th><th>Reporter</th><th>Date</th><th>Actions</th></tr></thead>
            <tbody>
              ${reports.map(r => `<tr><td>${r.id}</td><td>${r.type}</td><td>${r.title}</td><td><span class="status-badge status-${r.status.replace(/\s+/g, '-')}">${r.status}</span></td><td>${r.location}</td><td>${r.reporter || 'Unknown'}</td><td>${new Date(r.created_at).toLocaleDateString()}</td><td><form method="post" action="/admin/report/${r.id}/delete" style="display:inline;"><button class="btn btn-danger" onclick="return confirm('Delete report ${r.title}?')" style="font-size:11px;padding:4px 6px;">Delete</button></form></td></tr>`).join('')}
            </tbody>
          </table>
        ` : '<p>No reports recorded.</p>'}
      </div>
    </section>

    <section class="section-grid">
      <div class="table-card">
        <h2>Lost items</h2>
        ${lostReports && lostReports.length ? `
          <table>
            <thead><tr><th>ID</th><th>Title</th><th>Status</th><th>Location</th><th>Reporter</th><th>Date</th><th>Actions</th></tr></thead>
            <tbody>
              ${lostReports.map(r => `<tr><td>${r.id}</td><td>${r.title}</td><td><span class="status-badge status-${r.status.replace(/\s+/g, '-')}">${r.status}</span></td><td>${r.location}</td><td>${r.reporter || 'Unknown'}</td><td>${new Date(r.created_at).toLocaleDateString()}</td><td><form method="post" action="/admin/report/${r.id}/delete" style="display:inline;"><button class="btn btn-danger" onclick="return confirm('Delete lost report ${r.title}?')" style="font-size:11px;padding:4px 6px;">Delete</button></form></td></tr>`).join('')}
            </tbody>
          </table>
        ` : '<p>No lost reports found.</p>'}
      </div>
      <div class="table-card">
        <h2>Found items</h2>
        ${foundReports && foundReports.length ? `
          <table>
            <thead><tr><th>ID</th><th>Title</th><th>Status</th><th>Location</th><th>Reporter</th><th>Date</th><th>Actions</th></tr></thead>
            <tbody>
              ${foundReports.map(r => `<tr><td>${r.id}</td><td>${r.title}</td><td><span class="status-badge status-${r.status.replace(/\s+/g, '-')}">${r.status}</span></td><td>${r.location}</td><td>${r.reporter || 'Unknown'}</td><td>${new Date(r.created_at).toLocaleDateString()}</td><td><form method="post" action="/admin/report/${r.id}/delete" style="display:inline;"><button class="btn btn-danger" onclick="return confirm('Delete found report ${r.title}?')" style="font-size:11px;padding:4px 6px;">Delete</button></form></td></tr>`).join('')}
            </tbody>
          </table>
        ` : '<p>No found reports found.</p>'}
      </div>
    </section>
  ` 
}) %>
