<%- include('layout', { body: `
<section class="page-header">
  <div>
    <h1>Admin Dashboard</h1>
    <p>Control accounts, review all lost and found reports, and keep the security office informed.</p>
  </div>
  <a class="button" href="/admin/add-user">Create new user</a>
</section>
<section class="dashboard-summary">
  <div class="status-card status-card-found">
    <h3>Total users</h3>
    <p>${users.length}</p>
  </div>
  <div class="status-card status-card-pending">
    <h3>Total reports</h3>
    <p>${reports.length}</p>
  </div>
</section>
<section class="section-grid">
  <div class="table-card">
    <h2>Users</h2>
    ${users.length ? `
      <table>
        <thead><tr><th>ID</th><th>Name</th><th>Email</th><th>Username</th><th>Role</th><th>Phone</th></tr></thead>
        <tbody>
          ${users.map(u => `
            <tr><td>${u.id}</td><td>${u.full_name}</td><td>${u.email}</td><td>${u.username}</td><td>${u.role}</td><td>${u.phone_number || '-'}</td></tr>
          `).join('')}
        </tbody>
      </table>
    ` : '<p>No users found.</p>'}
  </div>
  <div class="table-card">
    <h2>All reports</h2>
    ${reports.length ? `
      <table>
        <thead><tr><th>ID</th><th>Type</th><th>Title</th><th>Status</th><th>Location</th><th>Reporter</th><th>Date</th></tr></thead>
        <tbody>
          ${reports.map(r => `
            <tr><td>${r.id}</td><td>${r.type}</td><td>${r.title}</td><td><span class="status-badge status-${r.status.replace(/\s+/g, '-')}">${r.status}</span></td><td>${r.location}</td><td>${r.reporter || 'Unknown'}</td><td>${new Date(r.created_at).toLocaleDateString()}</td></tr>
          `).join('')}
        </tbody>
      </table>
    ` : '<p>No reports recorded.</p>'}
  </div>
</section>
` }) %>
