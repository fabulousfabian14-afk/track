<%- include('layout', { body: `
<section class="admin-grid">
  <div class="panel">
    <h1>Admin Dashboard</h1>
    <p>Manage users, review all reports, and coordinate security operations.</p>
    <a class="button" href="/admin/add-user">Create new user</a>
  </div>
  <div class="panel">
    <h2>Users</h2>
    ${users.length ? `
      <table>
        <thead><tr><th>ID</th><th>Name</th><th>Email</th><th>Username</th><th>Role</th><th>Phone</th></thead>
        <tbody>
          ${users.map(u => `
            <tr><td>${u.id}</td><td>${u.full_name}</td><td>${u.email}</td><td>${u.username}</td><td>${u.role}</td><td>${u.phone_number || '-'}</td></tr>
          `).join('')}
        </tbody>
      </table>
    ` : '<p>No users found.</p>'}
  </div>
</section>
<section class="panel">
  <h2>All reports</h2>
  ${reports.length ? `
    <table>
      <thead><tr><th>ID</th><th>Type</th><th>Title</th><th>Status</th><th>Location</th><th>Reporter</th><th>Date</th></tr></thead>
      <tbody>
        ${reports.map(r => `
          <tr><td>${r.id}</td><td>${r.type}</td><td>${r.title}</td><td>${r.status}</td><td>${r.location}</td><td>${r.reporter || 'Unknown'}</td><td>${r.created_at}</td></tr>
        `).join('')}
      </tbody>
    </table>
  ` : '<p>No reports recorded.</p>'}
</section>
` }) %>
